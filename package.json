{
  "name": "@cinatra-ai/trigger-agent",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "description": "Configures a per-run trigger — immediate, scheduled, or recurring — so the workflow runs at the right time.",
  "type": "module",
  "files": [
    "cinatra",
    "skills"
  ],
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "dependencies": [],
    "fieldRenderers": [
      {
        "id": "@cinatra-ai/trigger-agent:configure",
        "kind": "trigger-configure",
        "priority": 60
      },
      {
        "id": "@cinatra-ai/trigger-agent:confirm",
        "kind": "trigger-confirm",
        "priority": 60
      }
    ]
  }
}
